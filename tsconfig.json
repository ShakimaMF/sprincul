{
  "compilerOptions": {
    "target": "es2016",
    "module": "es6",
    "moduleResolution": "bundler",
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmitOnError": false,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src/Sprincul.ts",
    "src/types.ts",
    "tests"
  ],
  "exclude": [
    "tests"
  ]
}

{
  "name": "sprincul",
  "version": "0.1.0",
  "description": "A lightweight, browser-side JS framework for adding reactivity to HTML.",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "source": "src/index.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.min.js",
  "jsdelivr": "./dist/index.min.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "author": {
    "name": "Shakima Franklin",
    "email": "shakima@sinfullycoded.com",
    "url": "https://sinfullycoded.com"
  },
  "license": "MIT",
  "scripts": {
    "watch": "bun build src/index.ts --target=browser --format=esm --outdir=dist --sourcemap=external --watch",
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build src/index.ts --target=browser --format=esm --outdir=dist --sourcemap=external && bun build src/index.ts --target=browser --format=esm --outdir=dist --minify --sourcemap=external --entry-naming [dir]/[name].min.[ext]",
    "build:types": "tsc",
    "prepublishOnly": "bun run build"
  },
  "targets": {
    "main": {
      "optimize": true,
      "context": "browser",
      "includeNodeModules": ["nanostores"]
    }
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.9",
    "@types/bun": "^1.3.11",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "nanostores": "^1.2.0"
  }
}

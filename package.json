{
  "name": "@shakimamf/sprincul",
  "version": "0.0.0",
  "type": "module",
  "files": ["dist"],
  "source": "src/index.ts",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "watch": "bun build src/index.ts --target=browser --format=esm --outdir=dist --watch",
    "build": "bun build src/index.ts --target=browser --format=esm --outdir=dist --minify --sourcemap",
    "test": "vitest"
  },
  "targets": {
    "main": {
      "optimize": true,
      "context": "browser",
      "includeNodeModules": ["morphdom"]
    }
  },
  "devDependencies": {
    "@parcel/packager-ts": "^2.16.0",
    "@parcel/transformer-typescript-types": "^2.16.0",
    "@vitest/ui": "^2.1.9",
    "happy-dom": "^15.11.7",
    "typescript": "^5.9.3",
    "vitest": "^4.0.3"
  },
  "dependencies": {
    "morphdom": "^2.7.7"
  }
}
